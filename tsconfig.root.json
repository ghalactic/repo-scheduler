{
  "compilerOptions": {
    "allowJs": true,
    "composite": true,
    "esModuleInterop": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ESNext",
    "tsBuildInfoFile": "artifacts/tsbuild/root.tsbuildinfo"
  },
  "include": ["**/*.ts", "**/*.js"],
  "exclude": [
    ".makefiles",
    "artifacts",
    "node_modules",
    "dist/**/dist",
    "src/platform"
  ]
}
