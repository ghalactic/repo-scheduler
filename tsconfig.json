{
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "strict": true,
    "target": "ESNext"
  },
  "exclude": ["dist", "artifacts", "dist", ".makefiles"],
  "include": ["**/*.js", "**/*.ts", ".agents/**/*.js"]
}
